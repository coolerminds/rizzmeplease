# Environment
# Set one provider key only.
# For Grok/xAI production, keep OPENAI_API_KEY empty and set XAI_API_KEY.
OPENAI_API_KEY=
XAI_API_KEY=xai-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
XAI_BASE_URL=https://api.x.ai/v1
# For xAI, set a Grok model (for example: grok-3)
OPENAI_MODEL=grok-3
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Redis (optional for MVP)
REDIS_URL=redis://localhost:6379

# App Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=https://rizzmeow.com,https://www.rizzmeow.com

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_REQUESTS_PER_DAY=100
